# ============================================================================
# AWS Secrets Manager — secret names used by the AgentCore Runtime
# ============================================================================
GITHUB_SECRET_NAME=github-pr-agent/github

# ============================================================================
# Bedrock Model
# Defaults to Amazon Nova Pro (300K context). Swap for Claude Sonnet 4 if preferred.
# ============================================================================
BEDROCK_MODEL_ID=arn:aws:bedrock:us-east-1:YOUR_ACCOUNT_ID:inference-profile/global.anthropic.claude-sonnet-4-20250514-v1:0

# ============================================================================
# Repository filtering (comma-separated owner/repo)
# Leave empty to allow all repos.
# ============================================================================
ALLOWED_REPOS=your-org/your-repo

# ============================================================================
# Terraform plan validation
# Repos listed here will have GitHub Actions logs scanned for Terraform plans.
# ============================================================================
TERRAFORM_VALIDATION_REPOS=

# ============================================================================
# Organization policy checking
# Set to 'true' to enable. Add policy docs to the policies/ directory.
# See policies/IMPLEMENTATION.md to upgrade to vector-based retrieval.
# ============================================================================
ORG_POLICY_CHECK_ENABLED=false

# ============================================================================
# AWS / Runtime
# ============================================================================
AWS_REGION=us-east-1
LOG_LEVEL=info
PORT=3000
