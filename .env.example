# ============================================================================
# AWS deployment targets (used by CDK)
# ============================================================================
AWS_ACCOUNT=000000000000
AWS_REGION=us-east-1
STAGE=dev

# ============================================================================
# GitHub credentials
# Name of the Secrets Manager secret that holds app_id, webhook_secret,
# and private_key for the GitHub App.
# ============================================================================
GITHUB_SECRET_NAME=github-pr-agent/github

# ============================================================================
# Bedrock model
# Bedrock model ID or inference profile ARN. For GitHub Actions deploys, store
# this as the BEDROCK_MODEL_ID repository secret. For local deploys/runs, set it
# here or export it in your shell before running CDK/scripts.
# ============================================================================
BEDROCK_MODEL_ID=

# ============================================================================
# Repository filtering (comma-separated owner/repo)
# Required for production safety. Comma-separated owner/repo allowlist.
# Set ALLOWED_REPOS=* only for local experiments where reviewing every installed
# repository is intentional.
# ============================================================================
ALLOWED_REPOS=your-org/your-repo

# ============================================================================
# Terraform plan validation
# Repos listed here will have GitHub Actions logs scanned for Terraform plans.
# Leave empty to disable for all repos.
# ============================================================================
TERRAFORM_VALIDATION_REPOS=

# ============================================================================
# Rate limiting
# Maximum PR reviews per repo per calendar week. CDK creates the S3 bucket
# automatically — RATE_LIMIT_BUCKET is injected at deploy time.
# ============================================================================
WEEKLY_REVIEW_LIMIT=2

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=info

# ============================================================================
# Local development — scripts/run_local.py only
# GITHUB_TOKEN replaces the GitHub App; set it to a personal access token
# with repo scope. Secrets Manager is skipped entirely when this is set.
# DRY_RUN prints the review to stdout instead of posting it to GitHub.
# ============================================================================
GITHUB_TOKEN=
DRY_RUN=false
