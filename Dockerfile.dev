FROM python:3.11-slim

# Node.js 20 (for CDK CLI)
RUN apt-get update && apt-get install -y --no-install-recommends \
        curl git \
    && curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# Docker CLI + buildx plugin — daemon runs on host via mounted socket
COPY --from=docker:27-cli /usr/local/bin/docker /usr/local/bin/docker
COPY --from=docker/buildx-bin:latest /buildx /usr/lib/docker/cli-plugins/docker-buildx

# CDK CLI
RUN npm install -g aws-cdk

ENV VIRTUAL_ENV=/opt/venv
RUN python -m venv $VIRTUAL_ENV
ENV PATH="$VIRTUAL_ENV/bin:$PATH"

WORKDIR /workspace

# Python deps baked into image; rebuild when these files change
COPY requirements.txt .
COPY deploy/requirements.txt deploy/requirements.txt
RUN pip install --upgrade pip --quiet && \
    pip install --no-cache-dir \
        -r requirements.txt \
        -r deploy/requirements.txt \
        black flake8 mypy awscli

CMD ["/bin/bash"]
